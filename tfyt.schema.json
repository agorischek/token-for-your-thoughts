{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/agorischek/token-for-your-thoughts/releases/latest/download/tfyt.schema.json",
  "title": "Token For Your Thoughts Config",
  "description": "Configuration for tfyt. This schema defines the JSON form directly; the TOML form uses the same field names and structure.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional in-file schema association for JSON editors."
    },
    "env_file_path": {
      "type": "string",
      "description": "Optional path to an env file to load before resolving *_env fields. Relative paths are resolved relative to the config file."
    },
    "mcp": {
      "$ref": "#/$defs/mcp"
    },
    "destinations": {
      "type": "array",
      "description": "If omitted or empty, tfyt defaults to a single markdown file destination writing to FEEDBACK.md.",
      "items": {
        "$ref": "#/$defs/destination"
      }
    }
  },
  "$defs": {
    "mcp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tool_name": {
          "type": "string",
          "description": "Override the MCP tool name. Defaults to submit_feedback."
        },
        "tool_description": {
          "type": "string",
          "description": "Override the MCP tool description."
        }
      }
    },
    "destination": {
      "oneOf": [
        {
          "$ref": "#/$defs/fileDestination"
        },
        {
          "$ref": "#/$defs/gitDestination"
        },
        {
          "$ref": "#/$defs/commandDestination"
        },
        {
          "$ref": "#/$defs/processDestination"
        },
        {
          "$ref": "#/$defs/httpDestination"
        },
        {
          "$ref": "#/$defs/applicationInsightsDestination"
        },
        {
          "$ref": "#/$defs/githubDiscussionsDestination"
        },
        {
          "$ref": "#/$defs/sqlDestination"
        },
        {
          "$ref": "#/$defs/otelDestination"
        }
      ]
    },
    "format": {
      "type": "string",
      "enum": [
        "markdown",
        "json"
      ]
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "fileDestination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "file"
        },
        "path": {
          "type": "string",
          "description": "Output file path. Defaults to FEEDBACK.md for markdown or feedback.jsonl for json."
        },
        "format": {
          "$ref": "#/$defs/format"
        }
      },
      "required": [
        "type"
      ]
    },
    "gitDestination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "git"
        },
        "path": {
          "type": "string",
          "description": "Backward-compatible alias for directory."
        },
        "directory": {
          "type": "string",
          "description": "Directory on the feedback branch that receives one file per feedback item."
        },
        "format": {
          "$ref": "#/$defs/format"
        },
        "branch": {
          "type": "string"
        },
        "remote": {
          "type": "string"
        },
        "push": {
          "type": "boolean"
        },
        "commit_message": {
          "type": "string"
        }
      },
      "required": [
        "type"
      ]
    },
    "commandDestination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "command"
        },
        "command": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "content_mode": {
          "type": "string",
          "enum": [
            "json",
            "args"
          ],
          "description": "How tfyt passes feedback to the subprocess. Defaults to json."
        }
      },
      "required": [
        "type",
        "command"
      ]
    },
    "processDestination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "process"
        },
        "command": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "method": {
          "type": "string",
          "description": "JSON-RPC method name. Defaults to submit_feedback."
        }
      },
      "required": [
        "type",
        "command"
      ]
    },
    "httpDestination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "http"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "url_env": {
          "type": "string",
          "description": "Env var name for the URL. If nonempty, this overrides url."
        },
        "method": {
          "type": "string",
          "description": "HTTP method. Defaults to POST."
        },
        "headers": {
          "$ref": "#/$defs/headers"
        },
        "headers_env": {
          "type": "string",
          "description": "Env var name for a JSON object of headers. If nonempty, this overrides headers."
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "success_statuses": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 100,
            "maximum": 599
          }
        }
      },
      "required": [
        "type"
      ],
      "allOf": [
        {
          "anyOf": [
            {
              "required": [
                "url"
              ]
            },
            {
              "required": [
                "url_env"
              ]
            }
          ]
        }
      ]
    },
    "applicationInsightsDestination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "application_insights"
        },
        "connection_string": {
          "type": "string"
        },
        "connection_string_env": {
          "type": "string",
          "description": "Env var name for the connection string. If nonempty, this overrides connection_string."
        },
        "event_name": {
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "allOf": [
        {
          "anyOf": [
            {
              "required": [
                "connection_string"
              ]
            },
            {
              "required": [
                "connection_string_env"
              ]
            }
          ]
        }
      ]
    },
    "githubDiscussionsDestination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "github_discussions"
        },
        "repository": {
          "type": "string",
          "description": "Repository in owner/repo form where discussions should be created."
        },
        "category": {
          "type": "string",
          "description": "Discussion category name or slug. Ignored when category_id is set."
        },
        "category_id": {
          "type": "string",
          "description": "Explicit GitHub discussion category node ID."
        },
        "token": {
          "type": "string"
        },
        "token_env": {
          "type": "string",
          "description": "Env var name for the GitHub token. If nonempty, this overrides token. If omitted and token is empty, tfyt falls back to GITHUB_TOKEN."
        },
        "title_template": {
          "type": "string",
          "description": "Go text/template for the discussion title. Defaults to Feedback {{ .ID }} from {{ .Provider }}."
        }
      },
      "required": [
        "type",
        "repository"
      ],
      "allOf": [
        {
          "anyOf": [
            {
              "required": [
                "category"
              ]
            },
            {
              "required": [
                "category_id"
              ]
            }
          ]
        }
      ]
    },
    "sqlDestination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "sql"
        },
        "driver": {
          "type": "string"
        },
        "dsn": {
          "type": "string"
        },
        "table": {
          "type": "string"
        },
        "auto_create": {
          "type": "boolean"
        },
        "create_statement": {
          "type": "string"
        },
        "insert_statement": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "driver",
        "dsn",
        "insert_statement"
      ]
    },
    "otelDestination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "otel"
        },
        "endpoint": {
          "type": "string"
        },
        "endpoint_env": {
          "type": "string",
          "description": "Env var name for the OTLP endpoint. If nonempty, this overrides endpoint."
        },
        "headers": {
          "$ref": "#/$defs/headers"
        },
        "headers_env": {
          "type": "string",
          "description": "Env var name for a JSON object of headers. If nonempty, this overrides headers."
        },
        "insecure": {
          "type": "boolean"
        },
        "service_name": {
          "type": "string"
        }
      },
      "required": [
        "type"
      ]
    }
  }
}
